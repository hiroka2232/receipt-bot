# ── Discord ──────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here

# レシート画像を投稿するチャンネルのID（Discordで右クリック→IDをコピー）
RECEIPT_CHANNEL_ID=123456789012345678

# 収入を報告するチャンネルのID（領収書チャンネルと同じIDでも可）
INCOME_CHANNEL_ID=123456789012345678

# ── Gemini (Google AI Studio) ─────────────────────────────
# https://aistudio.google.com/app/apikey で取得（無料）
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ── Google APIs（サービスアカウント） ─────────────────────
# service_account.json をこのフォルダに置いてください
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json

# Google Drive: 領収書フォルダのID
# フォルダURLの末尾: drive.google.com/drive/folders/【ここ】
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id_here

# Google Sheets: スプレッドシートのID
# URLの /d/【ここ】/edit 部分
GOOGLE_SHEETS_ID=your_spreadsheet_id_here
