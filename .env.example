# ── Discord ──────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here

# ── Gemini (Google AI Studio) ─────────────────────────────
# https://aistudio.google.com/app/apikey で取得（無料）
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ══════════════════════════════════════════════════════════
# 記録先プロファイル
# ──────────────────────────────────────────────────────────
# チャンネルごとに別アカウント・別ドライブへ記録できる。
# 1プロファイル = {対象チャンネル, 記録モード, スプレッドシート, Driveフォルダ,
#                 Drive認証トークン}。PROFILE_1_*, PROFILE_2_* … と番号で増やす。
#
# MODE: receipt=レシート画像のみ / income=収入テキストのみ / both=両方
# SHEET_ID       : スプレッドシートID（URLの /d/【ここ】/edit）。空でよい＝
#                  起動後 !初期化 で月シート一式を自動生成する。
# DRIVE_FOLDER_ID: 領収書フォルダのID（フォルダURLの末尾）
# DRIVE_TOKEN_*  : そのフォルダを持つアカウントの OAuth トークン。
#                  auth_drive.py をローカルで実行して作る（アカウントごとに1回）。
#
# ★サービスアカウント(service_account.json)は全プロファイル共通。
#   各スプレッドシートを service_account の client_email に「編集者」で共有すること。
#   Drive だけはフォルダ所有アカウントの OAuth が要る（サービスアカウントは
#   マイドライブ容量を持たずアップロードできないため）。
# ══════════════════════════════════════════════════════════

PROFILE_1_NAME=個人
PROFILE_1_CHANNEL=123456789012345678
PROFILE_1_MODE=both
PROFILE_1_SHEET_ID=your_spreadsheet_id_here
PROFILE_1_DRIVE_FOLDER_ID=your_google_drive_folder_id_here
PROFILE_1_DRIVE_TOKEN_FILE=drive_token_1.json
# サーバ(Docker)では代わりに1行JSONで渡す（設定するとファイルより優先）:
# PROFILE_1_DRIVE_TOKEN_JSON={"token":"...","refresh_token":"...",...}

# 2つ目のチャンネル（別アカウント・別ドライブ）を追加する例:
# PROFILE_2_NAME=サークル
# PROFILE_2_CHANNEL=234567890123456789
# PROFILE_2_MODE=both
# PROFILE_2_SHEET_ID=...
# PROFILE_2_DRIVE_FOLDER_ID=...
# PROFILE_2_DRIVE_TOKEN_FILE=drive_token_2.json

# ── サービスアカウント（Sheets書き込み・全プロファイル共通）──────
# 【A】ファイルで渡す（ローカル既定）
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json
# 【B】サーバ(Docker)は1行JSONで（設定するとファイルより優先）
#      1行化: (Get-Content service_account.json -Raw | ConvertFrom-Json | ConvertTo-Json -Compress)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# 対話認証（ブラウザを開くOAuth）を許可するか。
# ローカルで初めてDriveトークンを作るときだけ 1。サーバでは必ず 0（未設定=0）。
ALLOW_INTERACTIVE_AUTH=0

# ══════════════════════════════════════════════════════════
# 【後方互換】PROFILE_1_* が1つも無い場合、下の旧形式から
# 単一プロファイルを組み立てる（従来の単一アカウント運用）。
# ══════════════════════════════════════════════════════════
# RECEIPT_CHANNEL_ID=123456789012345678
# INCOME_CHANNEL_ID=123456789012345678
# GOOGLE_SHEETS_ID=your_spreadsheet_id_here
# GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id_here
# GOOGLE_DRIVE_TOKEN_FILE=drive_token.json
