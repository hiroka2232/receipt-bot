# ── Discord ──────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here

# レシート画像を投稿するチャンネルのID（Discordで右クリック→IDをコピー）
RECEIPT_CHANNEL_ID=123456789012345678

# 収入を報告するチャンネルのID（領収書チャンネルと同じIDでも可）
INCOME_CHANNEL_ID=123456789012345678

# ── Gemini (Google AI Studio) ─────────────────────────────
# https://aistudio.google.com/app/apikey で取得（無料）
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ── Google Sheets / Drive ─────────────────────────────────
# Google Drive: 領収書フォルダのID（フォルダURLの末尾）
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id_here
# Google Sheets: スプレッドシートのID（URLの /d/【ここ】/edit 部分）
GOOGLE_SHEETS_ID=your_spreadsheet_id_here

# ══════════════════════════════════════════════════════════
# 秘密情報の渡し方は2通り。どちらか一方でOK。
#
# 【A】ローカル / テスト向け: ファイルを置く（下の *_FILE を使う）
#      service_account.json と drive_token.json をこのフォルダに置く。
# 【B】サーバ / Docker 向け : JSONの中身を環境変数に入れる（下の *_JSON）
#      → サーバに秘密ファイルを置かなくて済む。JSONは必ず1行にすること。
# ══════════════════════════════════════════════════════════

# 【A】ファイルで渡す場合（ローカル既定）
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json
GOOGLE_DRIVE_TOKEN_FILE=drive_token.json

# 【B】環境変数で渡す場合（サーバ）。設定するとファイルより優先される。
#      1行化: PowerShellなら  (Get-Content service_account.json -Raw | ConvertFrom-Json | ConvertTo-Json -Compress)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# GOOGLE_DRIVE_TOKEN_JSON={"token":"...","refresh_token":"...",...}

# 対話認証（ブラウザを開くOAuth）を許可するか。
# ローカルで初めてDriveトークンを作るときだけ 1。サーバでは必ず 0（未設定=0）。
ALLOW_INTERACTIVE_AUTH=0
